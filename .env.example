# Slov-Lex AI Asistent — konfigurácia
# Skopírujte tento súbor ako .env a vyplňte hodnoty

# LLM REŽIM
# "api"   → Mistral API (odporúčané pre deploy)
# "local" → Ollama bežiaci na PC (na vývoj)
LLM_MODE=api

# MISTRAL API KĽÚČ (získajte zadarmo na https://console.mistral.ai)
MISTRAL_API_KEY=your_mistral_api_key_here

# LIMITY (voliteľné — predvolené hodnoty sú nastavené v config.py)
DAILY_QUERY_LIMIT=200
MONTHLY_BUDGET_EUR=20.0
